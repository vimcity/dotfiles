# Ghostty Configuration 
# ==================================================

theme = "Rose Pine Moon"

# Launch maximized
window-decoration = false
macos-titlebar-style = hidden
window-step-resize = true
window-save-state = always

# Font settings
# font-family = "CommitMono"
# adjust-cell-height = 35%
font-family = "JetBrains Mono NF"
adjust-cell-height = 26%
font-size = 16

# Background
# background-image = ~/dotfiles/ghostty/ghostty-bg.png
# background-image = ~/dotfiles/ghostty/bag.jpg
# background-image-fit = cover
# background-image-position = center
# background-image-opacity = 0.20
# background-blur=true
# background-opacity = 0.95

# Cursor and selection (bluish-grey white)
cursor-color = #c6d0f5

# Shell integration
shell-integration = zsh

# Copy on select
copy-on-select = clipboard

# Keybindings
keybind = shift+enter=text:\x1b\r

# Disable Ctrl+Shift+P (conflicts with other tools)
keybind = ctrl+shift+p=unbind

# Quick terminal toggle (Quake-style dropdown terminal)
keybind = global:cmd+shift+backquote=toggle_quick_terminal
