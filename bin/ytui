#!/usr/bin/env bash
# ytui — delegates to Go TUI when built, falls back to embedded bash
set -euo pipefail

GO_BIN="${YTUI_BIN:-$HOME/.local/bin/ytui}"
if [[ -x "$GO_BIN" ]]; then
    exec "$GO_BIN" "$@"
fi

# Fallback: legacy bash implementation lives alongside this script
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LEGACY="$SCRIPT_DIR/ytui.bash"
if [[ -f "$LEGACY" ]]; then
    exec bash "$LEGACY" "$@"
fi

echo "error: ytui not found — run: cd ~/Projects/ytui && task build" >&2
exit 1
