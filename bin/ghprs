#!/usr/bin/env bash
# ghprs - fzf PR picker for GitHub Enterprise

set -euo pipefail

PROJECTS_DIR="${PROJECTS_DIR:-$HOME/Projects}"
GHPRS_REPOS_FILE="${GHPRS_REPOS_FILE:-$HOME/dotfiles/.ghprs-repos.local}"
MODE="${1:-}"

die() {
    printf 'ghprs: %s\n' "$*" >&2
    exit 1
}

usage() {
    cat <<EOF
Usage:
  ghprs              Show open PRs for the current repo, or focus repos outside a repo
  ghprs review       Show open PRs requesting your review, with your review state in the list
  ghprs mine         Show open PRs authored by you, scoped the same way
  ghprs here         Show all open PRs for the current repo
  ghprs focus        Show all open PRs for the configured focus repo list
  ghprs repos        Print the configured focus repo list
  ghprs project      Pick a repo from GH_ORG and show its open PRs (legacy)

Focus repos:
  Read from GHPRS_REPOS_FILE, defaulting to:
  $GHPRS_REPOS_FILE
  Use one owner/repo per line. Blank lines and # comments are ignored.

Actions:
  enter              Open selected PR in nvim gh-review when repo exists locally
  ctrl-o             Open selected PR in browser
  ctrl-y             Copy PR URL
  ctrl-a             Assign yourself as reviewer
EOF
}

list_focus_repos() {
    if [[ ! -f "$GHPRS_REPOS_FILE" ]]; then
        die "focus repo file not found: $GHPRS_REPOS_FILE"
    fi

    sed -E 's/[[:space:]]+#.*$//; /^[[:space:]]*(#|$)/d; s/^[[:space:]]+//; s/[[:space:]]+$//' "$GHPRS_REPOS_FILE"
}

require() {
    for cmd in "$@"; do
        command -v "$cmd" >/dev/null 2>&1 || die "required command not found: $cmd"
    done
}

case "$MODE" in
-h | --help | help)
    usage
    exit 0
    ;;
repos | focus-repos)
    printf 'Focus repo file: %s\n\n' "$GHPRS_REPOS_FILE"
    list_focus_repos
    exit 0
    ;;
esac

GH_HOST="${GH_HOST:?GH_HOST is required}"
GH_ORG="${GH_ORG:?GH_ORG is required}"
GHPRS_ME="${GHPRS_ME:?GHPRS_ME is required}"

require gh fzf jq

FIELDS="number,title,repository,author,updatedAt,isDraft,url"
REPO_FIELDS="number,title,author,updatedAt,isDraft,url,reviewDecision,reviewRequests"
REVIEW_FIELDS="number,title,author,updatedAt,isDraft,url,reviewDecision,latestReviews"
REVIEW_SEARCH="review-requested:@me"

current_repo() {
    GH_HOST="$GH_HOST" gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null || true
}

repo_name_from_nwo() {
    printf '%s' "${1##*/}"
}

inject_repo() {
    local repo="$1"
    local repo_name
    repo_name=$(repo_name_from_nwo "$repo")
    jq --arg name "$repo_name" --arg nwo "$repo" 'map(. + {repository: {name: $name, nameWithOwner: $nwo}})'
}

fetch_repo_all() {
    local repo="$1"
    GH_HOST="$GH_HOST" gh pr list \
        --repo "$repo" \
        --state=open \
        --limit=100 \
        --json "$REPO_FIELDS" |
        inject_repo "$repo"
}

fetch_repo_mine() {
    local repo="$1"
    GH_HOST="$GH_HOST" gh search prs \
        --repo "$repo" \
        --author=@me \
        --state=open \
        --limit=100 \
        --json "$FIELDS"
}

fetch_repo_review() {
    local repo="$1"
    GH_HOST="$GH_HOST" gh pr list \
        --repo "$repo" \
        --search "$REVIEW_SEARCH" \
        --state=open \
        --limit=100 \
        --json "$REVIEW_FIELDS" |
        jq --arg me "$GHPRS_ME" --arg repo "$repo" '
            map(
                . + {
                    repository: {
                        name: ($repo | split("/") | last),
                        nameWithOwner: $repo
                    },
                    myReviewState: (
                        [ .latestReviews[]?
                          | select(.author.login == $me)
                          | {state: .state, submittedAt: .submittedAt}
                        ]
                        | sort_by(.submittedAt)
                        | last
                        | .state // ""
                    )
                }
            )
        '
}

fetch_focus() {
    local filter="${1:-all}"
    local tmpdir
    local repos=()
    local focus_repo
    while IFS= read -r focus_repo; do
        repos+=("$focus_repo")
    done < <(list_focus_repos)
    [[ "${#repos[@]}" -gt 0 ]] || die "focus repo file has no repos: $GHPRS_REPOS_FILE"

    tmpdir=$(mktemp -d)
    trap 'rm -rf "$tmpdir"' RETURN

    local pids=()
    local index=0
    local repo
    for repo in "${repos[@]}"; do
        case "$filter" in
        all)
            fetch_repo_all "$repo" >"$tmpdir/$index.json" &
            ;;
        mine)
            fetch_repo_mine "$repo" >"$tmpdir/$index.json" &
            ;;
        review)
            fetch_repo_review "$repo" >"$tmpdir/$index.json" &
            ;;
        esac
        pids+=("$!")
        index=$((index + 1))
    done

    local pid
    for pid in "${pids[@]}"; do
        wait "$pid"
    done

    jq -s '[ .[][] ] | unique_by(.url) | sort_by(.updatedAt) | reverse' "$tmpdir"/*.json
}

fetch_project() {
    local repo
    repo=$(GH_HOST="$GH_HOST" gh repo list "$GH_ORG" \
        --limit=200 \
        --json nameWithOwner \
        --jq '.[].nameWithOwner' |
        fzf \
            --prompt="repo> " \
            --height=40% \
            --reverse \
            --header="Pick a repository (ESC to cancel)") || return 1

    fetch_repo_all "$repo"
}

format_all() {
    jq -r '
    def reset:    "\u001b[0m";
    def blue:     "\u001b[38;5;111m";
    def mauve:    "\u001b[38;5;183m";
    def green:    "\u001b[38;5;114m";
    def yellow:   "\u001b[38;5;229m";
    def red:      "\u001b[38;5;210m";
    def flamingo: "\u001b[38;5;217m";
    def overlay:  "\u001b[38;5;244m";
    def rpad(n): . + (" " * n) | .[0:n];

    def rel_time:
      now as $now | (. | fromdate) as $ep | ($now - $ep) as $d |
      if $d < 3600 then "\($d / 60 | floor)m"
      elif $d < 86400 then "\($d / 3600 | floor)h"
      elif $d < 604800 then "\($d / 86400 | floor)d"
      else "\($d / 604800 | floor)w"
      end;

    def age_col:
      now as $now | (. | fromdate) as $ep | ($now - $ep) as $d |
      if $d < 86400 then green
      elif $d < 604800 then yellow
      else red
      end;

    def status($draft; $decision; $mine):
      if $draft then [overlay, "draft"]
      elif $mine == "APPROVED" then [green, "approved"]
      elif $mine == "CHANGES_REQUESTED" then [yellow, "changes"]
      elif $mine == "COMMENTED" then [overlay, "comment"]
      elif $decision == "APPROVED" then [green, "approved"]
      elif $decision == "CHANGES_REQUESTED" then [yellow, "changes"]
      elif $decision == "REVIEW_REQUIRED" then [red, "review"]
      else [overlay, "open"]
      end;

    .[] |
    (.updatedAt | rel_time) as $age |
    (.updatedAt | age_col) as $acol |
    status(.isDraft; (.reviewDecision // ""); (.myReviewState // "")) as [$scol, $status] |
    (.title | if length > 60 then .[0:60] + "..." else . end) as $title |
    "\(.url)\t" +
    (blue + (.repository.name | rpad(25)) + reset) + " " +
    (mauve + ("#" + (.number | tostring) | rpad(6)) + reset) + " " +
    ($scol + ($status | rpad(8)) + reset) + "  " +
    ($title | rpad(62)) + " " +
    (flamingo + (.author.login | rpad(12)) + reset) + " " +
    ($acol + ($age | rpad(4)) + reset)
  ' <<<"$1"
}

open_browser() {
    local url="$1"
    case "$(uname -s)" in
    Darwin) open "$url" ;;
    Linux) xdg-open "$url" >/dev/null 2>&1 || true ;;
    *) printf '%s\n' "$url" ;;
    esac
}

open_in_nvim() {
    local url="$1"
    local full_repo number repo_name repo_path nvim_cmd
    full_repo=$(printf '%s' "$url" | sed -E 's|https?://[^/]+/([^/]+/[^/]+)/pull/[0-9]+|\1|')
    number=$(printf '%s' "$url" | grep -oE '[0-9]+$')
    repo_name=$(repo_name_from_nwo "$full_repo")

    if [[ -d "$PROJECTS_DIR/$repo_name" ]]; then
        repo_path="$PROJECTS_DIR/$repo_name"
    elif [[ -d "$PROJECTS_DIR/$full_repo" ]]; then
        repo_path="$PROJECTS_DIR/$full_repo"
    else
        printf 'ghprs: repo not found locally (tried %s/%s). Opening browser.\n' "$PROJECTS_DIR" "$repo_name" >&2
        open_browser "$url"
        return
    fi

    nvim_cmd="nvim -c \"lua vim.defer_fn(function() require('gh-review').open_number(${number}) end, 200)\""

    if [[ -n "${TMUX:-}" ]]; then
        tmux new-window -n "pr-${repo_name}-${number}" -c "$repo_path" "$nvim_cmd"
    else
        (cd "$repo_path" && eval "$nvim_cmd")
    fi
}

select_pr() {
    local mode="$1"
    local header="$2"
    local json="$3"
    local count lines selected url

    count=$(jq 'length' <<<"$json")
    if [[ "$count" -eq 0 ]]; then
        printf 'No open PRs found.\n'
        exit 0
    fi

    lines=$(format_all "$json")
    selected=$(
        printf '%s\n' "$lines" |
            fzf \
                --ansi \
                --delimiter=$'\t' \
                --with-nth='2..' \
                --prompt="${mode}> " \
                --header="${header}  (${count} PRs)
  enter:nvim  ctrl-o:browser  ctrl-y:copy url  ctrl-a:assign self" \
                --reverse \
                --height=50% \
                --min-height=14 \
                --no-preview \
                --bind="ctrl-o:execute-silent(url=\$(printf '%s' {} | cut -f1); open \"\$url\")" \
                --bind="ctrl-y:execute-silent(url=\$(printf '%s' {} | cut -f1); printf '%s' \"\$url\" | pbcopy)" \
                --bind="ctrl-a:execute-silent(url=\$(printf '%s' {} | cut -f1); repo=\$(printf '%s' \"\$url\" | sed -E 's|https?://[^/]+/([^/]+/[^/]+)/pull/[0-9]+|\1|'); number=\$(printf '%s' \"\$url\" | grep -oE '[0-9]+$'); GH_HOST=$GH_HOST gh pr edit \"\$number\" --repo \"\$repo\" --add-reviewer \"$GHPRS_ME\" >/dev/null 2>&1)"
    ) || exit 0

    [[ -z "$selected" ]] && exit 0
    url=$(printf '%s' "$selected" | cut -f1)
    open_in_nvim "$url"
}

main() {
    local repo json scope header filter
    repo=$(current_repo)

    case "$MODE" in
    "" | all)
        if [[ -n "$repo" ]]; then
            json=$(fetch_repo_all "$repo")
            header="  Open PRs in $repo"
            scope="here"
        else
            json=$(fetch_focus all)
            header="  Open PRs in focus repos"
            scope="focus"
        fi
        ;;
    here)
        [[ -n "$repo" ]] || die "not inside a GitHub repo"
        json=$(fetch_repo_all "$repo")
        header="  Open PRs in $repo"
        scope="here"
        ;;
    focus)
        json=$(fetch_focus all)
        header="  Open PRs in focus repos"
        scope="focus"
        ;;
    mine | review)
        filter="$MODE"
        if [[ -n "$repo" ]]; then
            if [[ "$filter" == "mine" ]]; then
                json=$(fetch_repo_mine "$repo")
                header="  PRs authored by you in $repo"
            else
                json=$(fetch_repo_review "$repo")
                header="  PRs requesting your review in $repo"
            fi
            scope="$filter"
        else
            json=$(fetch_focus "$filter")
            if [[ "$filter" == "mine" ]]; then
                header="  PRs authored by you in focus repos"
            else
                header="  PRs requesting your review in focus repos"
            fi
            scope="$filter"
        fi
        ;;
    project)
        json=$(fetch_project) || exit 0
        header="  Open PRs in selected repo"
        scope="project"
        ;;
    *)
        usage >&2
        die "unknown mode '$MODE'"
        ;;
    esac

    select_pr "$scope" "$header" "$json"
}

main
