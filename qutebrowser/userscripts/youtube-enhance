#!/usr/bin/env python3
"""Inject lightweight tweaks to tame YouTube in qutebrowser."""

from __future__ import annotations

import shutil
import subprocess
import textwrap


def main() -> None:
    qute = shutil.which("qutebrowser") or "qutebrowser"
    js = textwrap.dedent("""
        (() => {
          const selectors = [
            '#comments',
            '#sections ytd-reel-shelf-renderer',
            '#sections ytd-rich-grid-renderer > ytd-rich-section-renderer:nth-child(1)',
            '#related',
            '#owner #subscribe-button ytd-button-renderer',
            'ytd-browse[page-subtype="guide"]',
            'ytd-popup-container',
            'ytd-confirm-dialog-renderer',
          ];

          const hideElements = () => {
            selectors.forEach((selector) => {
              document.querySelectorAll(selector).forEach((node) => {
                node.dataset.quteHidden = '1';
                node.style.display = 'none';
              });
            });
          };

          const applyPlayerNorm = () => {
            const video = document.querySelector('video');
            if (video) {
              video.autoplay = false;
              video.currentTime = Math.max(0, video.currentTime - 0.01);
            }
          };

          const observer = new MutationObserver(() => {
            hideElements();
            applyPlayerNorm();
          });
          observer.observe(document.body, { childList: true, subtree: true });

          const theme = document.createElement('style');
          theme.dataset.quteYoutube = 'true';
          theme.textContent = `
            #container, ytd-app, ytd-watch-flexy, #page-manager {
              background-color: #232634 !important;
              color: #c6d0f5 !important;
            }
            ytd-watch-flexy ytd-watch-next-secondary-results-renderer,
            ytd-watch-next-secondary-results-renderer tp-yt-paper-tooltip,
            #secondary-inner ytd-item-section-renderer {
              border-left: 1px solid #414559 !important;
            }
            #primary, ytd-rich-grid-renderer, ytd-rich-grid-media, #contents ytd-rich-item-renderer {
              background: rgba(44, 47, 65, 0.9) !important;
            }
            ytd-browse #contents > ytd-rich-grid-renderer {
              background: transparent !important;
            }
          `;
          document.head.appendChild(theme);

          hideElements();
          applyPlayerNorm();
        })();
    """)

    subprocess.run(
        [qute, "--target", "window", ":jseval", js],
        check=False,
    )


if __name__ == "__main__":
    main()
