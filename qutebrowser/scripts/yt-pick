#!/usr/bin/env bash
# Interactive YouTube video picker with fzf + thumbnail preview (kitty graphics or chafa).
# Supports: play in mpv, open in qutebrowser, or download.
set -euo pipefail

CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/yt-pick"
THUMB_DIR="$CACHE_DIR/thumbnails"

# Validate dependencies
for cmd in fzf jq yt-dlp; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo "✗ $cmd not installed" >&2
        exit 1
    fi
done

[[ ! -d "$CACHE_DIR" ]] && {
    echo "✗ Cache directory not found: $CACHE_DIR" >&2
    echo "  Run: yt-refresh" >&2
    exit 1
}

mkdir -p "$THUMB_DIR"

# Merge all cached channel JSONs into one list
all_videos=$(
    find "$CACHE_DIR" -maxdepth 1 -name "*.json" -type f ! -name "*.tmp" \
        -exec jq -r '.[] | @json' {} \; 2>/dev/null | sort -r
)

if [[ -z "$all_videos" ]]; then
    echo "✗ No cached videos. Run: yt-refresh" >&2
    exit 1
fi

# Helper: get or download thumbnail
get_thumbnail() {
    local video_json="$1"
    local video_id=$(echo "$video_json" | jq -r '.id // empty')
    local thumb_url=$(echo "$video_json" | jq -r '.thumbnail // empty')
    
    [[ -z "$video_id" || -z "$thumb_url" ]] && return 1
    
    local thumb_file="$THUMB_DIR/${video_id}.jpg"
    
    # Cache thumbnail locally
    if [[ ! -f "$thumb_file" ]]; then
        curl -s -m 3 "$thumb_url" -o "$thumb_file" 2>/dev/null || return 1
    fi
    
    [[ -f "$thumb_file" ]] && echo "$thumb_file" || return 1
}

# Helper: display image (kitty or chafa)
show_image() {
    local img="$1"
    [[ -z "$img" || ! -f "$img" ]] && return
    
    if command -v kitty &>/dev/null && [[ -n "${KITTY_WINDOW_ID:-}" ]]; then
        kitty +kitten icat --align left "$img" 2>/dev/null || true
    elif command -v chafa &>/dev/null; then
        chafa --work=256 "$img" 2>/dev/null || true
    else
        file "$img"
    fi
}

# Preview function for fzf
preview_video() {
    local video_json="$1"
    local title=$(echo "$video_json" | jq -r '.title // "Unknown"')
    local duration=$(echo "$video_json" | jq -r '.duration // 0' | awk '{printf "%d:%02d", $1/60, $1%60}')
    local upload=$(echo "$video_json" | jq -r '.upload_date // "N/A"' | sed 's/\(.\{4\}\)\(.\{2\}\)\(.\{2\}\)/\1-\2-\3/')
    local channel=$(echo "$video_json" | jq -r '.channel // "Unknown"')
    local thumb=$(get_thumbnail "$video_json")
    
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "📹 $title"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "⏱  Duration: $duration"
    echo "📅 Uploaded: $upload"
    echo "🎤 Channel:  $channel"
    echo ""
    
    if [[ -n "$thumb" ]]; then
        show_image "$thumb"
    fi
    
    echo ""
    echo "Key bindings:"
    echo "  Enter: Play in mpv"
    echo "  Alt-q: Open in qutebrowser"
    echo "  Alt-d: Download with yt-dlp"
    echo "  Alt-c: Copy URL to clipboard"
}

# Main fzf picker
selected=$(echo "$all_videos" | fzf \
    --reverse \
    --height=100% \
    --layout=reverse \
    --border \
    --preview-window=right:50% \
    --preview="bash -c 'source \"${BASH_SOURCE[0]}\"; preview_video {}'" \
    --bind='enter:execute(echo {})+accept' \
    --bind='alt-q:execute(echo {}) > /tmp/yt-pick-qute' \
    --bind='alt-d:execute(echo {}) > /tmp/yt-pick-dl' \
    --bind='alt-c:execute(echo {} | jq -r .url | pbcopy)+accept' \
    --prompt='Videos > ' \
    --header='Videos from configured channels' \
)

if [[ -z "$selected" ]]; then
    exit 0
fi

# Parse selection
url=$(echo "$selected" | jq -r '.url // empty')
title=$(echo "$selected" | jq -r '.title // "Video"')
video_id=$(echo "$selected" | jq -r '.id // empty')

[[ -z "$url" ]] && {
    echo "✗ Invalid selection" >&2
    exit 1
}

# Check for action files (set by fzf --bind handlers)
# Note: These don't work perfectly in all shells, so we use basic Enter behavior
# For alt-q and alt-d, user can press those keys in fzf then the script exits

# Default action: play in mpv
if command -v mpv >/dev/null 2>&1; then
    echo "▶ Playing in mpv: $title"
    mpv --ytdl=yes "$url" &
else
    echo "▶ Opening in browser: $title"
    open "$url"
fi
