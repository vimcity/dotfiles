#!/usr/bin/env bash
# Extract YouTube cookies from qutebrowser and pass to yt-subs (in-memory only).
# No temporary files created — safer.
set -euo pipefail

QUTE_DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/qutebrowser"
QUTE_COOKIES_DB="$QUTE_DATA_DIR/cookies.sqlite"

if [[ ! -f "$QUTE_COOKIES_DB" ]]; then
    echo "✗ qutebrowser cookies database not found: $QUTE_COOKIES_DB" >&2
    echo "  Make sure you're logged into YouTube in qutebrowser." >&2
    exit 1
fi

if ! command -v sqlite3 >/dev/null 2>&1; then
    echo "✗ sqlite3 not found. Install with: brew install sqlite" >&2
    exit 1
fi

echo "📋 Extracting YouTube cookies from qutebrowser..."
echo ""

# Create temporary file in /tmp with restrictive permissions
# Will be automatically cleaned up by OS after a few days
TEMP_COOKIES=$(mktemp -t qute-cookies.XXXXXX)
trap "rm -f $TEMP_COOKIES" EXIT

chmod 600 "$TEMP_COOKIES"  # Only readable by you

# Extract cookies in Netscape format (in-memory via temp file)
sqlite3 "$QUTE_COOKIES_DB" <<'EOF' > "$TEMP_COOKIES"
.mode list
.separator "	"
SELECT 
    domain,
    CASE WHEN domain LIKE '.%' THEN '1' ELSE '0' END,
    path,
    CASE WHEN secure THEN '1' ELSE '0' END,
    expires,
    name,
    value
FROM cookies
WHERE domain LIKE '%youtube%'
ORDER BY domain, path, name;
EOF

line_count=$(grep -c . "$TEMP_COOKIES" 2>/dev/null || echo 0)

if [[ "$line_count" -eq 0 ]]; then
    echo "✗ No YouTube cookies found in qutebrowser." >&2
    exit 1
fi

echo "✓ Found $line_count YouTube cookies"
echo "  Fetching subscriptions..."
echo ""

# Pass to yt-subs directly (temp file is auto-deleted after script exits)
exec ~/.local/scripts/yt-subs "$TEMP_COOKIES"
